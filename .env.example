DATA_PATH=data/machines.json
LEASE_STORE=file
# Required for Vercel/production real-provider use.
# Use a Redis-compatible REST endpoint such as Upstash/Vercel Marketplace Redis.
REDIS_REST_URL=
REDIS_REST_TOKEN=
REDIS_REST_KEY=checkout-proto:leases

PROVIDER=dry-run
ALLOW_UNPAID_MACHINE_CREATE=false
ALLOW_TEST_PAYMENTS_WITH_REAL_PROVIDER=false

# Required when PROVIDER=hetzner.
HETZNER_API_TOKEN=

# Required in production for Vercel Cron invocations.
# Vercel automatically sends this as:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Required for paid MPP checkout.
# Generate MPP_SECRET_KEY with: openssl rand -base64 32
MPP_SECRET_KEY=

# Required for Stripe Shared Payment Token (SPT) payments over MPP.
STRIPE_SECRET_KEY=
STRIPE_PROFILE_ID=
STRIPE_PAYMENT_METHOD_TYPES=card,link

# Default checkout price: $0.99 base fee + 5 cents/minute.
CHECKOUT_BASE_FEE_CENTS=99
PRICE_CENTS_PER_MINUTE=5
