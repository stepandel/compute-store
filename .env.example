DATA_PATH=data/machines.json
LEASE_STORE=file
# Required for Vercel/production real-provider use.
# Use a Redis-compatible REST endpoint such as Upstash/Vercel Marketplace Redis.
REDIS_REST_URL=
REDIS_REST_TOKEN=
REDIS_REST_KEY=checkout-proto:leases

# PROVIDER toggles provisioning mode:
#   dry-run (default) simulates every product.
#   live provisions each product on its own backend (CPU -> Hetzner, GPU -> RunPod).
PROVIDER=dry-run
ALLOW_UNPAID_MACHINE_CREATE=false

# Required when PROVIDER=live and a Hetzner-backed product (bare-linux-machine) is purchased.
HETZNER_API_TOKEN=

# Required when PROVIDER=live and a RunPod-backed product (gpu-h100-machine) is purchased.
RUNPOD_API_TOKEN=

# Required in production for Vercel Cron invocations.
# Vercel automatically sends this as:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Required for paid MPP checkout.
# Generate MPP_SECRET_KEY with: openssl rand -base64 32
MPP_SECRET_KEY=

# Required for Stripe Shared Payment Token (SPT) payments over MPP.
STRIPE_SECRET_KEY=
STRIPE_PROFILE_ID=
STRIPE_PAYMENT_METHOD_TYPES=card,link

# Per-product checkout pricing (flat base fee + per-minute rate).
# bare-linux-machine: $0.99 base + 5 cents/minute.
CHECKOUT_BASE_FEE_CENTS=99
PRICE_CENTS_PER_MINUTE=5
# gpu-h100-machine: $1.99 base + 9 cents/minute (above RunPod H100 cost).
GPU_CHECKOUT_BASE_FEE_CENTS=199
GPU_PRICE_CENTS_PER_MINUTE=9

# Async provisioning safety net: leases stuck in "provisioning" longer than
# this (e.g. the background task died) are failed by the expire cron. Default 10.
PROVISION_TIMEOUT_MINUTES=10

# Retention for terminated/failed leases before the expire cron prunes them
# (and their capability tokens) from the store. Default 1440 (24h).
PRUNE_RETENTION_MINUTES=1440

# Rate limiting. Reuses the REDIS_REST_* endpoint when configured (counters are
# global across instances); otherwise falls back to per-instance in-memory.
# RATE_LIMIT_DISABLED=true   # disable entirely (tests/local only)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_WRITE_MAX=30
RATE_LIMIT_READ_MAX=120
